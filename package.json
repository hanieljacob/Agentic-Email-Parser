{
  "name": "agentic-email-parser",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --check .",
    "check": "prettier --write . && eslint --fix",
    "backend": "dotenv -e .env -- python3 backend/ingest.py",
    "extract-server": "dotenv -e .env -- tsx backend/extract.ts --server",
    "migrate": "dotenv -e .env -- bash -c 'for f in migrations/*.sql; do echo \"--- $f\"; psql $DATABASE_URL < $f; done'",
    "ingest": "dotenv -e .env -- python3 backend/ingest.py",
    "extract": "dotenv -e .env -- tsx backend/extract.ts",
    "match": "dotenv -e .env -- tsx backend/match.ts",
    "seed": "dotenv -e .env -- tsx backend/scripts/seed.ts",
    "api": "dotenv -e .env -- tsx backend/api.ts",
    "setup": "createdb email_parser || true && pnpm migrate && pip install -r backend/requirements.txt"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^0.545.0",
    "mammoth": "^1.12.0",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.0.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.5"
  },
  "packageManager": "pnpm@10.30.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}